{
  "name": "contivon",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Contivon memory API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "license": "MIT",
  "author": "Prolixis",
  "repository": {
    "type": "git",
    "url": "https://github.com/prolixis/contivon-sdk"
  },
  "homepage": "https://contivon.com/sdk",
  "bugs": { "url": "https://github.com/prolixis/contivon-sdk/issues" },
  "keywords": ["ai", "memory", "llm", "rag", "vector-search", "agents", "contivon"],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
